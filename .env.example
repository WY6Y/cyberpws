# Flask
HOST=0.0.0.0
PORT=5001

# WeatherThief MQTT (OpenMQTTGateway rtl_433)
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=wy6y/weather
MQTT_USER=wy6y
MQTT_PASS=your_mqtt_password
GATEWAY_NAME=WeatherThief
AUTO_ENABLE_RF=1
RF_ACTIVE_RTL=3

# Pushover alerts (watchdog firmware restart notifications)
PUSHOVER_USER_KEY=your_pushover_user_key
PUSHOVER_API_TOKEN=your_pushover_api_token

# Station display
# Edit STATION_ID / coords in app.py if needed